@model SmartJobRecommender.Models.ViewModels.AnalyzeViewModel
@using SmartJobRecommender.Models.ViewModels

@{
    ViewData["Title"] = "Resume Analyzer";
}

<style>
    :root {
        --an-bg-a: #ecfeff;
        --an-bg-b: #fef3c7;
        --an-ink: #0f172a;
        --an-muted: #475569;
        --an-panel: rgba(255, 255, 255, 0.84);
        --an-cyan: #0e7490;
        --an-cyan-dark: #155e75;
        --an-amber: #d97706;
        --an-border: #dbe4ee;
    }

    .an-page {
        position: relative;
        padding: 1rem;
        min-height: calc(100vh - 120px);
        background:
            radial-gradient(circle at 8% 18%, #bae6fd 0%, transparent 34%),
            radial-gradient(circle at 90% 12%, #fde68a 0%, transparent 28%),
            linear-gradient(140deg, var(--an-bg-a) 0%, var(--an-bg-b) 100%);
        border-radius: 1.2rem;
        overflow: hidden;
    }

    .an-orb {
        position: absolute;
        border-radius: 999px;
        opacity: .35;
        pointer-events: none;
        animation: an-float 11s ease-in-out infinite;
    }

    .an-orb.one {
        width: 190px;
        height: 190px;
        right: -55px;
        top: -50px;
        background: #67e8f9;
    }

    .an-orb.two {
        width: 160px;
        height: 160px;
        left: -50px;
        bottom: -45px;
        background: #fcd34d;
        animation-delay: 1.6s;
    }

    @@keyframes an-float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(10px); }
    }

    .an-shell {
        max-width: 1150px;
        margin: 0 auto;
        position: relative;
        z-index: 1;
    }

    .an-hero {
        border-radius: 1.2rem;
        padding: 1.6rem;
        margin-bottom: 1rem;
        color: #fff;
        background: linear-gradient(150deg, #0e7490 0%, #0284c7 45%, #d97706 100%);
        box-shadow: 0 24px 50px rgba(14, 116, 144, .25);
    }

    .an-hero h1 {
        margin: 0;
        font-size: clamp(1.6rem, 2.4vw, 2.4rem);
        font-weight: 800;
        letter-spacing: -.02em;
    }

    .an-hero p {
        margin: .45rem 0 0;
        color: rgba(255,255,255,.92);
        font-size: 1rem;
    }

    .an-card {
        border: 1px solid rgba(148, 163, 184, .3);
        border-radius: 1.1rem;
        background: var(--an-panel);
        backdrop-filter: blur(6px);
        box-shadow: 0 18px 40px rgba(15, 23, 42, .1);
    }

    .an-form {
        padding: 1.4rem;
    }

    .an-label {
        display: block;
        font-size: .95rem;
        font-weight: 700;
        margin-bottom: .45rem;
        color: #1e293b;
    }

    .an-field {
        width: 100%;
        border: 1px solid var(--an-border);
        border-radius: .85rem;
        background: #fff;
        padding: .82rem .95rem;
        transition: box-shadow .2s ease, border-color .2s ease;
    }

    .an-field:focus {
        border-color: var(--an-cyan);
        box-shadow: 0 0 0 3px rgba(14, 116, 144, .16);
        outline: none;
    }

    .an-upload {
        border: 2px dashed #94a3b8;
        border-radius: .95rem;
        padding: 1.4rem;
        text-align: center;
        transition: border-color .2s ease, background-color .2s ease;
    }

    .an-upload:hover {
        border-color: #0e7490;
        background: rgba(255,255,255,.6);
    }

    .an-btn {
        width: 100%;
        border: 0;
        border-radius: .95rem;
        padding: .9rem 1rem;
        color: #fff;
        font-size: 1rem;
        font-weight: 700;
        background: linear-gradient(135deg, var(--an-cyan) 0%, var(--an-amber) 100%);
        box-shadow: 0 12px 26px rgba(217, 119, 6, .28);
        transition: transform .18s ease, box-shadow .18s ease;
    }

    .an-btn:hover {
        transform: translateY(-1px);
        box-shadow: 0 16px 30px rgba(217, 119, 6, .34);
    }

    .an-results-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1rem;
    }

    .an-result-card {
        padding: 1.15rem;
        border-radius: 1rem;
        border: 1px solid rgba(148, 163, 184, .25);
        background: rgba(255,255,255,.88);
    }

    .an-chip {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        padding: .22rem .65rem;
        font-size: .8rem;
        font-weight: 600;
    }

    .an-chip-skill {
        background: #cffafe;
        color: #0e7490;
    }

    .an-job-item {
        border: 1px solid #e2e8f0;
        border-radius: .85rem;
        padding: .9rem;
        background: #fff;
    }

    .an-score-good { color: #16a34a; }
    .an-score-mid { color: #d97706; }
    .an-score-low { color: #dc2626; }

    .loader {
        border: 4px solid #f3f4f6;
        border-top: 4px solid #0e7490;
        border-radius: 50%;
        width: 24px;
        height: 24px;
        animation: spin 1s linear infinite;
        display: inline-block;
        vertical-align: middle;
    }

    @@keyframes spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }

    .prose h4 {
        font-size: 1.1rem;
        font-weight: 700;
        margin-top: 1.2rem;
        margin-bottom: .45rem;
        color: #0f172a;
    }

    .prose ul {
        list-style-type: disc;
        padding-left: 1.4rem;
        margin-top: .4rem;
    }

    .prose li {
        margin-bottom: .4rem;
        color: #334155;
    }

    @@media (min-width: 1024px) {
        .an-page {
            padding: 1.4rem;
        }

        .an-form {
            padding: 1.7rem;
        }

        .an-results-grid {
            grid-template-columns: 1fr 2fr;
        }
    }
</style>

<div class="an-page">
    <div class="an-orb one"></div>
    <div class="an-orb two"></div>

    <div class="an-shell">
        <section class="an-hero">
            <h1>Map your skills to your next role.</h1>
            <p>Upload your resume, choose your dream role, and get targeted recommendations in minutes.</p>
        </section>

        <section id="upload-section" class="an-card @(Model.AnalysisCompleted ? "hidden" : "")">
            <div class="an-form">
                <form asp-action="Analyze" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3 text-sm"></div>

                    <div class="mb-4">
                        <label asp-for="ResumeFile" class="an-label"></label>
                        <div id="file-upload-area" class="an-upload cursor-pointer">
                            <input asp-for="ResumeFile" type="file" id="resume-file-input" class="hidden" accept=".pdf,.docx">
                            <svg class="mx-auto h-12 w-12 text-slate-400" stroke="currentColor" fill="none" viewBox="0 0 48 48" aria-hidden="true">
                                <path d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                            <p class="mt-2 text-sm text-slate-600"><span class="font-semibold text-cyan-700">Click to upload</span> or drag and drop</p>
                            <p class="text-xs text-slate-500">PDF or DOCX accepted</p>
                            <p id="file-name" class="mt-2 text-sm font-semibold text-emerald-700"></p>
                        </div>
                        <span asp-validation-for="ResumeFile" class="text-danger text-sm"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="DreamJobTitle" class="an-label"></label>
                        <input asp-for="DreamJobTitle" class="an-field" placeholder="e.g. Data Analyst, Product Designer" />
                        <span asp-validation-for="DreamJobTitle" class="text-danger text-sm"></span>
                    </div>

                    <button type="submit" class="an-btn">Analyze My Path</button>
                </form>
            </div>
        </section>

        @if (Model.AnalysisCompleted)
        {
            <section id="results-section" class="mt-4">
                <h2 class="text-2xl font-bold text-slate-900 mb-3">Analysis Complete</h2>

                <div class="an-results-grid">
                    <div class="an-result-card">
                        <h3 class="text-lg font-bold text-cyan-700 mb-3">Extracted Skills (@Model.ExtractedSkills.Count)</h3>
                        <div class="flex flex-wrap gap-2">
                            @foreach (var skill in Model.ExtractedSkills)
                            {
                                <span class="an-chip an-chip-skill">@skill</span>
                            }
                        </div>
                    </div>

                    <div class="an-result-card">
                        <h3 class="text-lg font-bold text-emerald-700 mb-2">Top Job Recommendations</h3>
                        <p class="text-slate-600 mb-3 text-sm">These roles best match your current skill profile.</p>

                        <div class="space-y-3">
                            @if (!Model.RecommendedJobs.Any())
                            {
                                <p class="text-red-600">No matching jobs found. Add more jobs and skills in the admin panel.</p>
                            }

                            @foreach (var job in Model.RecommendedJobs)
                            {
                                <div class="an-job-item">
                                    <div class="flex justify-between items-start gap-3">
                                        <div>
                                            <h4 class="text-base font-bold text-slate-900">@job.Title (@job.Company)</h4>
                                            <p class="text-xs text-slate-500">@job.Location</p>
                                        </div>
                                        <div class="text-right">
                                            <p class="text-xl font-extrabold @(job.MatchScore >= 80 ? "an-score-good" : (job.MatchScore >= 50 ? "an-score-mid" : "an-score-low"))">@job.MatchScore%</p>
                                            <p class="text-[11px] text-slate-500">Match</p>
                                        </div>
                                    </div>

                                    <div class="mt-2">
                                        <p class="font-semibold text-xs text-slate-700">Skills Needed (Missing: @job.MissingSkills.Count)</p>
                                        <div class="flex flex-wrap gap-1 mt-1">
                                            @foreach (var skill in job.RequiredSkills)
                                            {
                                                var hasSkill = Model.ExtractedSkills.Any(s => s.Equals(skill, StringComparison.OrdinalIgnoreCase));
                                                <span class="text-xs px-2 py-0.5 rounded @(hasSkill ? "bg-emerald-100 text-emerald-800" : "bg-rose-100 text-rose-800 font-semibold")">@skill</span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <div class="an-result-card mt-4">
                    <h3 class="text-xl font-bold text-indigo-700 border-b pb-2 mb-3">Path to Dream Job: @Model.DreamJobTitle</h3>

                    <div id="analysis-results-container">
                        @if (!string.IsNullOrEmpty(Model.DreamJobAnalysisResult))
                        {
                            <div class="prose max-w-none">
                                @Html.Raw(Model.DreamJobAnalysisResult)
                            </div>
                        }
                    </div>

                    <div id="analysis-loader" class="hidden mt-4 text-center">
                        <div class="inline-block loader mr-2"></div>
                        <p class="text-slate-600">Analyzing skills against market requirements...</p>
                    </div>

                    @Html.AntiForgeryToken()
                    <button id="run-dream-job-analysis-btn" data-job-title="@Model.DreamJobTitle" class="mt-4 w-full bg-indigo-600 text-white px-4 py-3 rounded-md hover:bg-indigo-700 transition-colors">
                        Run Gap Analysis and Course Suggestions
                    </button>
                </div>
            </section>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const fileInput = document.getElementById('resume-file-input');
            const fileNameDisplay = document.getElementById('file-name');
            const fileUploadArea = document.getElementById('file-upload-area');

            if (fileInput) {
                fileInput.addEventListener('change', function () {
                    if (this.files.length > 0) {
                        fileNameDisplay.textContent = 'Selected: ' + this.files[0].name;
                        fileUploadArea.classList.add('border-cyan-500', 'bg-cyan-50');
                    } else {
                        fileNameDisplay.textContent = '';
                        fileUploadArea.classList.remove('border-cyan-500', 'bg-cyan-50');
                    }
                });
            }

            const runAnalysisBtn = document.getElementById('run-dream-job-analysis-btn');
            if (runAnalysisBtn) {
                runAnalysisBtn.addEventListener('click', async function () {
                    const jobTitle = this.dataset.jobTitle;
                    const loader = document.getElementById('analysis-loader');
                    const resultsContainer = document.getElementById('analysis-results-container');

                    loader.classList.remove('hidden');
                    this.disabled = true;
                    resultsContainer.innerHTML = '';

                    const antiForgeryToken = document.querySelector('input[name="__RequestVerificationToken"]').value;

                    try {
                        const response = await fetch('@Url.Action("GenerateDreamJobAnalysis", "Home")', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'RequestVerificationToken': antiForgeryToken
                            },
                            body: JSON.stringify({ dreamJobTitle: jobTitle })
                        });

                        const data = await response.json();

                        if (data.success) {
                            let htmlResult = data.result
                                .replace(/\r?\n\r?\n/g, '<br><br>')
                                .replace(/### (.*)/g, '<h4>$1</h4>')
                                .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');

                            resultsContainer.innerHTML = `<div class="prose max-w-none">${htmlResult}</div>`;
                        } else {
                            resultsContainer.innerHTML = `<p class="text-red-500">${data.message || "An unknown error occurred during AI analysis."}</p>`;
                        }
                    } catch (error) {
                        resultsContainer.innerHTML = '<p class="text-red-500">Failed to connect to the analysis service.</p>';
                        console.error('Fetch Error:', error);
                    } finally {
                        loader.classList.add('hidden');
                        this.disabled = false;
                    }
                });
            }
        });
    </script>
}
