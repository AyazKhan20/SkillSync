@{
    ViewData["Title"] = "SkillSync - Bridge the Gap";
}

<div class="relative min-h-screen bg-[#0f172a] overflow-hidden">
    <!-- Hero Section -->
    <div class="relative pt-32 pb-20 md:pt-48 md:pb-32 px-6">
        <!-- Animated Background Elements -->
        <div class="absolute inset-0 z-0">
            <div class="absolute top-0 left-1/4 w-[500px] h-[500px] bg-blue-600/10 blur-[120px] rounded-full animate-pulse"></div>
            <div class="absolute bottom-0 right-1/4 w-[500px] h-[500px] bg-indigo-600/10 blur-[120px] rounded-full animate-pulse delay-700"></div>
        </div>

        <div class="relative z-10 max-w-6xl mx-auto text-center">
            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-blue-500/10 border border-blue-400/20 text-blue-400 text-sm font-bold mb-8 backdrop-blur-md">
                <span class="relative flex h-3 w-3">
                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"></span>
                    <span class="relative inline-flex rounded-full h-3 w-3 bg-blue-500"></span>
                </span>
                Mapping the future of careers
            </div>

            <h1 class="text-5xl md:text-[120px] font-black text-white mb-8 tracking-tighter leading-none">
                SYNC YOUR <br/><span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-indigo-400">POTENTIAL.</span>
            </h1>

            <p class="text-xl md:text-2xl text-slate-400 max-w-3xl mx-auto mb-12 font-medium leading-relaxed">
                The world's most intelligent career roadmap engine. We analyze your skills, detect your gaps, and build your bridge to success.
            </p>

            <div class="flex flex-col sm:flex-row gap-6 justify-center items-center">
                <a asp-area="Identity" asp-page="/Account/Register" 
                   class="group relative inline-flex items-center justify-center px-10 py-5 font-black text-white transition-all duration-200 bg-blue-600 rounded-2xl hover:bg-blue-700 hover:-translate-y-1 shadow-2xl shadow-blue-500/30">
                    GET STARTED NOW
                    <svg class="w-6 h-6 ml-2 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
                </a>
                <a href="#features" 
                   class="inline-flex items-center justify-center px-10 py-5 font-bold text-slate-300 transition-all duration-200 bg-slate-800/80 backdrop-blur-md border border-slate-700 rounded-2xl hover:bg-slate-700 hover:text-white">
                    EXPLORE FEATURES
                </a>
            </div>
        </div>
    </div>

    <!-- Features Bento Grid -->
    <section id="features" class="relative z-10 max-w-7xl mx-auto px-6 py-24">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <div class="p-10 rounded-[2.5rem] bg-[#1e293b]/50 border border-slate-700/50 backdrop-blur-xl hover:border-blue-500/50 transition-all group">
                <div class="w-16 h-16 bg-blue-500/10 rounded-2xl flex items-center justify-center text-3xl mb-8 group-hover:scale-110 transition-transform">🔍</div>
                <h3 class="text-2xl font-black text-white mb-4">Smart Extraction</h3>
                <p class="text-slate-400 leading-relaxed font-medium">Deep AI analysis of your resume to identify hidden competencies you didn't even know you had.</p>
            </div>
            <div class="p-10 rounded-[2.5rem] bg-[#1e293b]/50 border border-slate-700/50 backdrop-blur-xl hover:border-indigo-500/50 transition-all group">
                <div class="w-16 h-16 bg-indigo-500/10 rounded-2xl flex items-center justify-center text-3xl mb-8 group-hover:scale-110 transition-transform">🎯</div>
                <h3 class="text-2xl font-black text-white mb-4">Precision Match</h3>
                <p class="text-slate-400 leading-relaxed font-medium">See exactly how you stack up against your dream roles with real-time industry requirement mapping.</p>
            </div>
            <div class="p-10 rounded-[2.5rem] bg-[#1e293b]/50 border border-slate-700/50 backdrop-blur-xl hover:border-blue-500/50 transition-all group">
                <div class="w-16 h-16 bg-blue-500/10 rounded-2xl flex items-center justify-center text-3xl mb-8 group-hover:scale-110 transition-transform">🚀</div>
                <h3 class="text-2xl font-black text-white mb-4">Roadmap Build</h3>
                <p class="text-slate-400 leading-relaxed font-medium">Get actionable, step-by-step instructions on the exact skills you need to acquire next.</p>
            </div>
        </div>
    </section>
</div>

