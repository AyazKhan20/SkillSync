@{
    ViewData["Title"] = "Analyze Resume";
}

<div class="pt-32 pb-20 px-8">
    <div class="max-w-4xl mx-auto">
        <div class="text-center mb-16">
            <h1 class="text-6xl font-black text-slate-900 tracking-tighter mb-4">Skill Analyzer</h1>
            <p class="text-xl text-slate-500 font-medium">Upload your resume and let our engine map your potential.</p>
        </div>

        <div class="bg-white p-12 rounded-[3rem] border-2 border-dashed border-slate-200 hover:border-blue-400 transition-all group relative overflow-hidden">
            <form asp-action="Analyze" method="post" enctype="multipart/form-data">
                <div class="flex flex-col items-center justify-center space-y-8">
                    <div class="w-24 h-24 bg-blue-50 text-blue-600 rounded-3xl flex items-center justify-center text-4xl group-hover:scale-110 transition-transform shadow-sm">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
                        </svg>
                    </div>
                    
                    <div class="text-center">
                        <label class="block cursor-pointer">
                            <span class="sr-only">Choose Resume</span>
                            <input type="file" name="resume" class="block w-full text-sm text-slate-500
                              file:mr-4 file:py-3 file:px-8
                              file:rounded-2xl file:border-0
                              file:text-sm file:font-semibold
                              file:bg-blue-600 file:text-white
                              hover:file:bg-blue-700
                              transition-all" required accept=".pdf"/>
                        </label>
                        <p class="mt-4 text-slate-400 font-medium italic">Supports PDF only (Max 5MB)</p>
                    </div>

                    <button type="submit" class="w-full py-5 bg-slate-900 text-white font-black rounded-2xl text-xl hover:bg-black transition-all shadow-2xl">
                        START ANALYSIS
                    </button>
                </div>
            </form>
            <div class="absolute -z-10 bg-blue-50/50 inset-0 pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity"></div>
        </div>
    </div>
</div>
