@{
    ViewData["Title"] = "SkillSync Dashboard";
}

<div class="pt-32 pb-20 px-8">
    <div class="max-w-7xl mx-auto">
        <div class="flex flex-col md:flex-row justify-between items-end gap-6 mb-12">
            <div>
                <h1 class="text-5xl font-black text-slate-900 tracking-tighter mb-2">My Dashboard</h1>
                <p class="text-slate-500 font-medium">Ready to sync your potential today?</p>
            </div>
            <div class="flex gap-3">
                <button class="bg-blue-600 text-white font-bold px-6 py-3 rounded-2xl hover:bg-blue-700 transition-all shadow-xl shadow-blue-500/20">
                    Upload Resume
                </button>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
            <div class="bg-white p-8 rounded-[2.5rem] border border-slate-100 shadow-sm">
                <span class="text-slate-400 font-bold uppercase tracking-widest text-xs mb-4 block">Overall Match</span>
                <div class="text-6xl font-black text-blue-600 mb-2">85%</div>
                <div class="h-2 w-full bg-slate-100 rounded-full overflow-hidden">
                    <div class="h-full bg-blue-600 w-[85%]"></div>
                </div>
            </div>
            <div class="bg-white p-8 rounded-[2.5rem] border border-slate-100 shadow-sm">
                <span class="text-slate-400 font-bold uppercase tracking-widest text-xs mb-4 block">Skills Detected</span>
                <div class="text-6xl font-black text-slate-900 mb-2">14</div>
                <p class="text-slate-400 font-medium">Mapped to industry standards</p>
            </div>
            <div class="bg-white p-8 rounded-[2.5rem] border border-slate-100 shadow-sm">
                <span class="text-slate-400 font-bold uppercase tracking-widest text-xs mb-4 block">Skill Gaps</span>
                <div class="text-6xl font-black text-amber-500 mb-2">3</div>
                <p class="text-slate-400 font-medium">High priority requirements</p>
            </div>
        </div>

        <div class="bg-slate-900 rounded-[3rem] p-12 text-white overflow-hidden relative">
            <div class="relative z-10">
                <h2 class="text-3xl font-black mb-8">Personalized Roadmap</h2>
                <div class="space-y-6">
                    <div class="flex items-center gap-6 p-6 bg-white/5 rounded-3xl border border-white/10">
                        <div class="w-12 h-12 bg-blue-600 rounded-2xl flex items-center justify-center font-bold">1</div>
                        <div>
                            <h4 class="font-bold text-xl">Master Advanced SQL</h4>
                            <p class="text-slate-400">Required for 80% of senior backend roles</p>
                        </div>
                    </div>
                    <div class="flex items-center gap-6 p-6 bg-white/5 rounded-3xl border border-white/10">
                        <div class="w-12 h-12 bg-indigo-600 rounded-2xl flex items-center justify-center font-bold">2</div>
                        <div>
                            <h4 class="font-bold text-xl">Cloud Infrastructure (Azure/AWS)</h4>
                            <p class="text-slate-400">Next logical step for your profile</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="absolute top-0 right-0 w-1/3 h-full bg-gradient-to-l from-blue-600/20 to-transparent"></div>
        </div>
    </div>
</div>
