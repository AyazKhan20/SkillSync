@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SkillSync</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        slate: {
                            50: '#f8fafc',
                            100: '#f1f5f9',
                            200: '#e2e8f0',
                            300: '#cbd5e1',
                            400: '#94a3b8',
                            500: '#64748b',
                            600: '#475569',
                            700: '#334155',
                            800: '#1e293b',
                            900: '#0f172a',
                            950: '#020617',
                        },
                        blue: {
                            50: '#eff6ff',
                            100: '#dbeafe',
                            200: '#bfdbfe',
                            300: '#93c5fd',
                            400: '#60a5fa',
                            500: '#3b82f6',
                            600: '#2563eb',
                            700: '#1d4ed8',
                            800: '#1e40af',
                            900: '#1e3a8a',
                        }
                    }
                }
            }
        }
    </script>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Space Grotesk', sans-serif; }
    </style>
</head>
<body class="bg-slate-900 scroll-smooth">
    <header class="fixed top-0 left-0 right-0 z-50 p-6">
        <nav class="max-w-7xl mx-auto flex items-center justify-between bg-slate-900/50 backdrop-blur-2xl border border-white/5 rounded-[2rem] px-10 py-5 shadow-2xl shadow-black/20">
            <a class="flex items-center gap-4 group" asp-controller="Home" asp-action="Index">
                <div class="w-12 h-12 bg-blue-600 rounded-2xl flex items-center justify-center font-black text-white text-2xl group-hover:scale-110 group-hover:rotate-12 transition-all shadow-xl shadow-blue-500/20">S</div>
                <span class="font-black text-3xl text-white tracking-tighter group-hover:text-blue-400 transition-colors">SKILLSYNC</span>
            </a>
            
            <div class="flex items-center gap-10">
                <ul class="navbar-nav hidden lg:flex items-center gap-8 list-none p-0 m-0">
                    <li><a class="text-slate-400 hover:text-white font-black tracking-widest text-xs uppercase transition-all" asp-controller="Home" asp-action="Index">HOME</a></li>
                    @if (SignInManager.IsSignedIn(User))
                    {
                        <li><a class="text-slate-400 hover:text-white font-black tracking-widest text-xs uppercase transition-all" asp-controller="Dashboard" asp-action="Index">DASHBOARD</a></li>
                        <li><a class="text-slate-400 hover:text-white font-black tracking-widest text-xs uppercase transition-all" asp-controller="Dashboard" asp-action="Analyze">ANALYZE</a></li>
                    }
                </ul>
                <div class="flex items-center gap-6">
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <main class="min-h-screen">
        @RenderBody()
    </main>

    <footer class="bg-slate-900 border-t border-white/5 py-12">
        <div class="max-w-7xl mx-auto px-8 flex justify-between items-center">
            <span class="text-slate-500 font-medium">© 2026 SkillSync Engine</span>
            <div class="flex gap-6">
                <a href="#" class="text-slate-500 hover:text-white transition-colors">Privacy</a>
                <a href="#" class="text-slate-500 hover:text-white transition-colors">API Docs</a>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
