@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<ul class="navbar-nav flex items-center gap-6 list-none m-0 p-0">
@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item">
        <a class="text-slate-400 font-black tracking-widest text-[10px] uppercase hover:text-white transition-all" asp-area="Identity" asp-page="/Account/Manage/Index">@User.Identity?.Name</a>
    </li>
    <li class="nav-item">
        <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button type="submit" class="bg-white/5 border border-white/10 text-slate-300 px-6 py-2.5 rounded-xl font-black text-xs tracking-widest uppercase hover:bg-white/10 hover:text-white transition-all">LOGOUT</button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="text-slate-400 font-black tracking-widest text-xs uppercase hover:text-white transition-all" asp-area="Identity" asp-page="/Account/Register">REGISTER</a>
    </li>
    <li class="nav-item">
        <a class="bg-blue-600 text-white px-8 py-3 rounded-2xl font-black text-xs tracking-widest hover:bg-white hover:text-blue-600 transition-all shadow-xl shadow-blue-500/20 uppercase" asp-area="Identity" asp-page="/Account/Login">LOGIN</a>
    </li>
}
</ul>
