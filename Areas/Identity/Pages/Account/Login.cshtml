@page
@model SmartJobRecommender.Areas.Identity.Pages.Account.LoginModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign In - Smart Job Recommender</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=Sora:wght@500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-cream: #fff7ed;
            --bg-sand: #ffedd5;
            --brand-teal: #0f766e;
            --brand-teal-dark: #115e59;
            --brand-orange: #ea580c;
            --panel: rgba(255, 255, 255, 0.86);
            --text-main: #1f2937;
            --text-muted: #6b7280;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            font-family: 'Outfit', sans-serif;
            min-height: 100vh;
            color: var(--text-main);
            background:
                radial-gradient(circle at 20% 20%, #99f6e4 0%, transparent 35%),
                radial-gradient(circle at 80% 10%, #fdba74 0%, transparent 30%),
                linear-gradient(135deg, var(--bg-cream) 0%, var(--bg-sand) 100%);
            overflow-x: hidden;
        }

        .floating-shape {
            position: absolute;
            border-radius: 999px;
            filter: blur(1px);
            animation: drift 10s ease-in-out infinite;
            opacity: 0.35;
            pointer-events: none;
        }

        .shape-a {
            width: 220px;
            height: 220px;
            top: -60px;
            right: -70px;
            background: #99f6e4;
        }

        .shape-b {
            width: 170px;
            height: 170px;
            bottom: -45px;
            left: -55px;
            background: #fed7aa;
            animation-delay: 1.4s;
        }

        @@keyframes drift {
            0%,
            100% {
                transform: translateY(0px);
            }

            50% {
                transform: translateY(8px);
            }
        }

        .auth-shell {
            min-height: 100vh;
            display: grid;
            grid-template-columns: 1fr;
            align-items: center;
            padding: 2rem 1rem;
            position: relative;
        }

        .auth-card {
            width: 100%;
            max-width: 1024px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: 1fr;
            border-radius: 1.5rem;
            overflow: hidden;
            background: var(--panel);
            backdrop-filter: blur(8px);
            box-shadow: 0 30px 70px rgba(15, 23, 42, 0.18);
            animation: rise 0.55s ease-out;
            position: relative;
            z-index: 2;
        }

        @@keyframes rise {
            from {
                opacity: 0;
                transform: translateY(16px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .auth-showcase {
            display: none;
            padding: 2.5rem;
            color: #ffffff;
            background: linear-gradient(155deg, #0f766e 0%, #0f766e 30%, #ea580c 100%);
        }

        .auth-showcase h1 {
            font-family: 'Sora', sans-serif;
            font-size: 2rem;
            line-height: 1.15;
            margin: 0 0 1rem 0;
        }

        .auth-showcase p {
            margin: 0;
            font-size: 1rem;
            color: rgba(255, 255, 255, 0.9);
        }

        .auth-form {
            padding: 2rem 1.25rem;
        }

        .brand-pill {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            font-family: 'Sora', sans-serif;
            font-weight: 700;
            font-size: 0.85rem;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            color: var(--brand-teal-dark);
            background: rgba(15, 118, 110, 0.08);
            border: 1px solid rgba(15, 118, 110, 0.2);
            border-radius: 999px;
            padding: 0.35rem 0.75rem;
            margin-bottom: 1rem;
        }

        .auth-form h2 {
            margin: 0 0 0.4rem 0;
            font-family: 'Sora', sans-serif;
            font-size: 1.7rem;
            line-height: 1.2;
            color: #111827;
        }

        .subtext {
            margin: 0 0 1.25rem 0;
            color: var(--text-muted);
        }

        .field-wrap {
            margin-bottom: 1rem;
        }

        .field-wrap label {
            display: block;
            font-size: 0.88rem;
            font-weight: 600;
            margin-bottom: 0.4rem;
            color: #334155;
        }

        .field-wrap input[type="email"],
        .field-wrap input[type="password"] {
            width: 100%;
            border-radius: 0.8rem;
            border: 1px solid #d1d5db;
            padding: 0.75rem 0.9rem;
            background: #ffffff;
            color: #111827;
            transition: border-color 0.2s ease, box-shadow 0.2s ease;
        }

        .field-wrap input[type="email"]:focus,
        .field-wrap input[type="password"]:focus {
            outline: none;
            border-color: var(--brand-teal);
            box-shadow: 0 0 0 3px rgba(15, 118, 110, 0.15);
        }

        .remember-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 0.6rem;
            margin: 0.25rem 0 1.25rem;
            font-size: 0.92rem;
        }

        .remember-row label {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            color: #334155;
        }

        .remember-row a {
            color: var(--brand-teal-dark);
            text-decoration: none;
            font-weight: 600;
        }

        .remember-row a:hover {
            text-decoration: underline;
        }

        .cta-btn {
            width: 100%;
            border: 0;
            border-radius: 0.9rem;
            padding: 0.85rem 1rem;
            font-family: 'Sora', sans-serif;
            font-size: 1rem;
            font-weight: 600;
            color: #ffffff;
            background: linear-gradient(135deg, var(--brand-teal) 0%, var(--brand-orange) 100%);
            box-shadow: 0 12px 25px rgba(234, 88, 12, 0.24);
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        .cta-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 16px 30px rgba(234, 88, 12, 0.28);
        }

        .validation-summary {
            margin-bottom: 0.9rem;
            font-size: 0.9rem;
        }

        .text-danger {
            display: block;
            margin-top: 0.35rem;
            font-size: 0.82rem;
            color: #b91c1c;
        }

        .foot-link {
            margin-top: 1.2rem;
            text-align: center;
            color: #475569;
            font-size: 0.92rem;
        }

        .foot-link a {
            color: var(--brand-teal-dark);
            text-decoration: none;
            font-weight: 700;
        }

        .foot-link a:hover {
            text-decoration: underline;
        }

        @@media (min-width: 900px) {
            .auth-card {
                grid-template-columns: 1.05fr 1fr;
            }

            .auth-showcase {
                display: flex;
                flex-direction: column;
                justify-content: center;
                gap: 1.25rem;
                position: relative;
            }

            .auth-showcase::after {
                content: "";
                position: absolute;
                width: 190px;
                height: 190px;
                right: -60px;
                bottom: -55px;
                background: rgba(255, 255, 255, 0.14);
                border-radius: 999px;
            }

            .auth-form {
                padding: 2.6rem;
            }
        }
    </style>
</head>
<body>
    <div class="floating-shape shape-a"></div>
    <div class="floating-shape shape-b"></div>

    <div class="auth-shell">
        <div class="auth-card">
            <aside class="auth-showcase">
                <h1>Turn your skills into your next opportunity.</h1>
                <p>Sign in to analyze your resume, map your strengths, and discover roles that match your growth goals.</p>
            </aside>

            <section class="auth-form">
                <div class="brand-pill">SJR Workspace</div>
                <h2>Welcome back</h2>
                <p class="subtext">Continue building your personalized career path.</p>

                <form id="account" method="post" asp-route-returnUrl="@Model.ReturnUrl" novalidate>
                    <div asp-validation-summary="ModelOnly" class="text-danger validation-summary" role="alert"></div>

                    <div class="field-wrap">
                        <label asp-for="Input.Email"></label>
                        <input asp-for="Input.Email" autocomplete="username" aria-required="true" placeholder="you@example.com" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <div class="field-wrap">
                        <label asp-for="Input.Password"></label>
                        <input asp-for="Input.Password" autocomplete="current-password" aria-required="true" placeholder="Enter your password" />
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <div class="remember-row">
                        <label asp-for="Input.RememberMe">
                            <input asp-for="Input.RememberMe" /> @Html.DisplayNameFor(m => m.Input.RememberMe)
                        </label>
                        <a asp-page="./ForgotPassword">Forgot password?</a>
                    </div>

                    <button type="submit" class="cta-btn">Sign in</button>
                </form>

                <p class="foot-link">
                    New to Smart Job Recommender?
                    <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Create an account</a>
                </p>
            </section>
        </div>
    </div>

    <partial name="_ValidationScriptsPartial" />
</body>
</html>
